    <!-- LOGIQUE DE L'ASSISTANT IA ET DU BOUTON COPIER -->
    <script>
        function startAiGeneration() {
            const userInput = document.getElementById('user-description').value.trim();
            const resultCard = document.getElementById('ai-result-card');
            const textOutput = document.getElementById('ai-text-output');
            const copyBtn = document.getElementById('copy-btn');
            
            if (userInput === "") {
                alert("Oups ! Écris d'abord une petite description ou un mot-clé avant de générer.");
                return;
            }

            // Affiche le cadre du résultat en mode chargement
            resultCard.classList.remove('hidden');
            textOutput.innerHTML = "Génération de votre stratégie TikTok en cours... ⚡";
            
            // Réinitialiser le bouton copier
            copyBtn.innerHTML = '<i class="fas fa-copy"></i> Copier';
            copyBtn.classList.remove('bg-green-600', 'text-white');

            // Intelligence contextuelle rapide
            setTimeout(() => {
                const responseTemplate = 
                    `🤖 STRATÉGIE IA & SCRIPT POUR : "${userInput}"\n\n` +
                    `1️⃣ CONCEPT GLOBAL : Créer une vidéo rythmée au format 9:16 de 45 secondes maximum qui résout immédiatement une frustration majeure de votre audience.\n\n` +
                    `2️⃣ ACCROCHE VIRALE (0 à 3 sec) : "Si vous faites du contenu ou du business sur le thème : ${userInput}, vous devez absolument tester cette méthode avant qu'elle ne soit saturée..."\n\n` +
                    `3️⃣ SCRIPT & VISUELS (3 à 35 sec) : \n` +
                    `- Étape 1 : Montrez votre écran ou le produit en action.\n` +
                    `- Étape 2 : Utilisez des sous-titres dynamiques bicolores (jaune et blanc) via CapCut.\n` +
                    `- Étape 3 : Ajoutez des coupures et zooms toutes les 2 secondes pour garder l'attention.\n\n` +
                    `4️⃣ APPEL À L'ACTION : "Enregistre cette vidéo pour ton prochain montage et abonne-toi à @CreatorProAfrica pour percer."`;

                textOutput.innerHTML = "";
                let index = 0;
                
                // Effet d'écriture machine pour faire pro
                function typingEffect() {
                    if (index < responseTemplate.length) {
                        textOutput.innerHTML += responseTemplate.charAt(index);
                        index++;
                        setTimeout(typingEffect, 10);
                    }
                }
                typingEffect();

            }, 800);
        }

        // Fonction pour copier le texte généré dans le presse-papier
        function copyToClipboard() {
            const textToCopy = document.getElementById('ai-text-output').innerText;
            const copyBtn = document.getElementById('copy-btn');

            if(!textToCopy || textToCopy.includes("Génération")) return;

            navigator.clipboard.writeText(textToCopy).then(() => {
                copyBtn.innerHTML = '<i class="fas fa-check"></i> Copié !';
                copyBtn.classList.add('bg-green-600', 'text-white');
            }).catch(err => {
                console.error('Erreur lors de la copie : ', err);
            });
        }
    </script>
